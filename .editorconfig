# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# HTML files
[*.html]
indent_style = space
indent_size = 2

# CSS files
[*.{css,scss,sass}]
indent_style = space
indent_size = 2

# JavaScript/JSON files
[*.{js,jsx,json}]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# XML/SVG files
[*.{xml,svg}]
indent_style = space
indent_size = 2

# Shell script files
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Python files
[*.py]
indent_style = space
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab
